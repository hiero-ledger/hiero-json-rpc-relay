# SPDX-License-Identifier: Apache-2.0
#
# Single source of truth for the versions of the Solo-based local network that
# CI workflows spin up to run tests against. Consumed by the "Load pinned
# versions" step in each workflow (loaded into $GITHUB_ENV).
#
# Kept up to date by the automated bump-network-versions workflow:
# the bot edits ONLY this file and opens a PR so CI runs against the new versions.
#
#   SOLO_VERSION    - @hashgraph/solo npm package version (no leading "v")
#   NETWORK_TAG     - hiero-consensus-node release tag
#   MIRROR_NODE_TAG - hiero-mirror-node release tag
SOLO_VERSION=0.68.0
NETWORK_TAG=v0.72.0
MIRROR_NODE_TAG=v0.151.0