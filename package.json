{
  "name": "root",
  "version": "0.77.0-SNAPSHOT",
  "devDependencies": {
    "@eslint/js": "^9.38.0",
    "@octokit/core": "^6.1.6",
    "@open-rpc/schema-utils-js": "^2.1.2",
    "@types/chai": "^5.2.3",
    "@types/chai-as-promised": "^8.0.2",
    "@types/co-body": "6.1.3",
    "@types/cors": "^2.8.12",
    "@types/find-config": "^1.0.4",
    "@types/koa__cors": "^5.0.1",
    "@types/lodash": "^4.17.7",
    "@types/mocha": "^10.0.10",
    "@types/node": "^24.9.1",
    "@types/sinon": "^17.0.4",
    "@types/uuid": "^11.0.0",
    "@typescript-eslint/eslint-plugin": "^8.44.1",
    "@typescript-eslint/parser": "^8.44.0",
    "@vercel/nft": "^1.3.2",
    "ajv": "^8.16.0",
    "ajv-formats": "^3.0.1",
    "axios-mock-adapter": "^2.1.0",
    "c8": "^10.1.3",
    "chai": "^6.0.1",
    "chai-as-promised": "^8.0.1",
    "chai-exclude": "^3.0.0",
    "eslint": "^9.34.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-n": "^17.21.3",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "execution-apis": "git://github.com/ethereum/execution-apis.git#7907424db935b93c2fe6a3c0faab943adebe8557",
    "globals": "^16.4.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.1.6",
    "mocha": "^11.7.1",
    "mocha-junit-reporter": "^2.2.1",
    "mocha-multi-reporters": "^1.5.1",
    "prettier": "^3.0.3",
    "proxyquire": "^2.1.3",
    "redis-memory-server": "^0.14.0",
    "replace": "^1.2.2",
    "sinon": "^21.0.0",
    "ts-mocha": "^11.1.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.3"
  },
  "scripts": {
    "acceptancetest": "c8 ts-mocha tests/server/acceptance/index.spec.ts --exit",
    "acceptancetest:api_batch1": "c8 ts-mocha tests/server/acceptance/index.spec.ts -g '@api-batch-1' --exit",
    "acceptancetest:api_batch2": "c8 ts-mocha tests/server/acceptance/index.spec.ts -g '@api-batch-2' --exit",
    "acceptancetest:api_batch3": "c8 ts-mocha tests/server/acceptance/index.spec.ts -g '@api-batch-3' --exit",
    "acceptancetest:erc20": "npm_package_version=0.0.1 c8 ts-mocha tests/server/acceptance/index.spec.ts -g '@erc20' --exit",
    "acceptancetest:ratelimiter": "c8 ts-mocha tests/ws-server/acceptance/index.spec.ts -g '@web-socket-ratelimiter' --exit && ts-mocha tests/server/acceptance/index.spec.ts -g '@ratelimiter' --exit",
    "acceptancetest:hbarlimiter_batch1": "HBAR_RATE_LIMIT_TINYBAR=7000000000 HBAR_RATE_LIMIT_BASIC=1000000000 HBAR_RATE_LIMIT_EXTENDED=1500000000 HBAR_RATE_LIMIT_PRIVILEGED=2000000000 c8 ts-mocha tests/server/acceptance/index.spec.ts -g '@hbarlimiter-batch1' --exit",
    "acceptancetest:hbarlimiter_batch2": "HBAR_RATE_LIMIT_BASIC=1000000000 HBAR_RATE_LIMIT_EXTENDED=1500000000 HBAR_RATE_LIMIT_PRIVILEGED=2000000000 c8 ts-mocha tests/server/acceptance/index.spec.ts -g '@hbarlimiter-batch2' --exit",
    "acceptancetest:hbarlimiter_batch3": "HBAR_RATE_LIMIT_TINYBAR=0 HBAR_RATE_LIMIT_BASIC=1000000000 HBAR_RATE_LIMIT_EXTENDED=1500000000 HBAR_RATE_LIMIT_PRIVILEGED=2000000000 c8 ts-mocha tests/server/acceptance/index.spec.ts -g '@hbarlimiter-batch3' --exit",
    "acceptancetest:tokencreate": "c8 ts-mocha tests/server/acceptance/index.spec.ts -g '@tokencreate' --exit",
    "acceptancetest:tokenmanagement": "c8 ts-mocha tests/server/acceptance/index.spec.ts -g '@tokenmanagement' --exit",
    "acceptancetest:htsprecompilev1": "c8 ts-mocha tests/server/acceptance/index.spec.ts -g '@htsprecompilev1' --exit",
    "acceptancetest:release": "c8 ts-mocha tests/server/acceptance/index.spec.ts -g '@release' --exit && ts-mocha tests/ws-server/acceptance/index.spec.ts -g '@release' --exit",
    "acceptancetest:release_http": "c8 ts-mocha tests/server/acceptance/index.spec.ts -g '@release' --exit",
    "acceptancetest:release_ws": "c8 ts-mocha tests/ws-server/acceptance/index.spec.ts -g '@release' --exit",
    "acceptancetest:protocol": "c8 ts-mocha tests/protocol/index.spec.ts -g '@protocol-acceptance' --exit",
    "acceptancetest:release_light": "c8 ts-mocha tests/server/acceptance/index.spec.ts -g '@release-light' --exit",
    "acceptancetest:ws": "c8 ts-mocha tests/ws-server/acceptance/index.spec.ts -g '@web-socket' --exit",
    "acceptancetest:ws_batch1": "c8 ts-mocha tests/ws-server/acceptance/index.spec.ts -g '@web-socket-batch-1' --exit",
    "acceptancetest:ws_batch2": "c8 ts-mocha tests/ws-server/acceptance/index.spec.ts -g '@web-socket-batch-2' --exit",
    "acceptancetest:ws_batch3": "c8 ts-mocha tests/ws-server/acceptance/index.spec.ts -g '@web-socket-batch-3' --exit",
    "acceptancetest:ws_newheads": "c8 ts-mocha tests/server/acceptance/index.spec.ts -g '@web-socket-newheads' --exit",
    "acceptancetest:precompile-calls": "c8 ts-mocha tests/server/acceptance/index.spec.ts -g '@precompile-calls' --exit",
    "acceptancetest:cache-service": "c8 ts-mocha tests/server/acceptance/index.spec.ts -g '@cache-service' --exit",
    "acceptancetest:rpc_api_schema_conformity": "c8 ts-mocha tests/server/acceptance/index.spec.ts -g '@api-conformity' --exit",
    "acceptancetest:serverconfig": "c8 ts-mocha tests/server/acceptance/index.spec.ts -g '@server-config' --exit",
    "acceptancetest:send_raw_transaction_extension": "c8 ts-mocha tests/server/acceptance/index.spec.ts -g '@sendRawTransactionExtension' --exit",
    "acceptancetest:json_rpc_compliance": "c8 ts-mocha tests/server/acceptance/index.spec.ts -g '@json-rpc-compliance' --exit",
    "acceptancetest:debug": "c8 ts-mocha tests/server/acceptance/index.spec.ts -g '@debug' --exit",
    "acceptancetest:xts": "c8 ts-mocha tests/server/acceptance/index.spec.ts -g '@xts' --exit",
    "acceptancetest:mirror-node-compatiblity": "c8 ts-mocha tests/server/acceptance/index.spec.ts -g '@mirror-node-compatiblity' --exit",
    "build": "npm run clean && npm run compile",
    "build-and-test": "npm run build && npm run test",
    "build:docker": "docker build . -t ${npm_package_name}",
    "clean": "rm -rf ./dist && rm -rf tsconfig.tsbuildinfo",
    "compile": "tsc -b tsconfig.json",
    "dev": "npm run build && tsc --watch",
    "deploy:docker": "docker push ghcr.io/hiero-ledger/${npm_package_name}:latest",
    "format": "npx prettier --write \"src/**/*.+(js|ts|json)\" \"tests/**/*.+(js|ts|json)\"",
    "hopp": "hopp test tests/server/hoppscotch.json -e tests/server/hopp-env.json",
    "lint": "npx eslint .",
    "start": "node dist/index.js",
    "start:ws": "RPC_HTTP_ENABLED=false RPC_WS_ENABLED=true node dist/index.js",
    "start:docker": "docker run --name hedera-relay -d -p 7546:7546 ${npm_package_name}:latest",
    "test": "c8 ts-mocha --recursive './tests/config-service/**/*.spec.ts' './tests/relay/**/*.spec.ts' './tests/server/integration/**/*.spec.ts' './tests/ws-server/unit/**/*.spec.ts' --exit",
    "test:relay": "c8 ts-mocha --recursive './tests/relay/**/*.spec.ts' --exit",
    "test:server": "c8 ts-mocha --recursive './tests/server/integration/**/*.spec.ts' --exit",
    "test:ws-server": "c8 ts-mocha --recursive './tests/ws-server/unit/**/*.spec.ts' --exit",
    "openrpctest": "ts-mocha tests/relay/lib/openrpc.spec.ts --exit",
    "bump-version": "SEM_VER=${npm_config_semver} SNAPSHOT=${npm_config_snapshot} node scripts/.bump-version.js",
    "prepare": "husky",
    "print-env": "node src/config-service/commands/printEnvs.ts"
  },
  "dependencies": {
    "@ethereumjs/rlp": "^10.0.0",
    "@ethereumjs/trie": "^6.2.1",
    "@ethereumjs/util": "^9.1.0",
    "@hashgraph/sdk": "^2.80.0",
    "@hoppscotch/cli": "0.30.0",
    "@koa/cors": "^5.0.0",
    "async-mutex": "^0.5.0",
    "axios": "^1.4.0",
    "axios-retry": "^4.5.0",
    "better-lookup": "^1.3.0",
    "co-body": "6.2.0",
    "dotenv": "^17.2.1",
    "ethers": "^6.15.0",
    "find-config": "^1.0.0",
    "json-bigint": "^1.0.0",
    "koa": "^3.0.1",
    "koa-websocket": "^7.0.0",
    "lodash": "^4.17.21",
    "lru-cache": "^11.1.0",
    "pino": "^10.1.0",
    "pino-pretty": "^13.1.2",
    "piscina": "^5.1.4",
    "prom-client": "^15.1.3",
    "redis": "^5.8.0",
    "uuid": "^13.0.0"
  },
  "overrides": {
    "protobufjs": "^7.2.4",
    "semver": "^7.5.3",
    "elliptic": "^6.6.1"
  },
  "lint-staged": {
    "src/**/*.ts": [
      "eslint --fix",
      "prettier --write"
    ],
    "tests/**/*.ts": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged"
    }
  }
}
